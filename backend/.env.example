PORT=5000
MONGODB_URI=mongodb://localhost:27017/sign_interpreter
JWT_SECRET=supersecretjwtkey_change_me_in_production

# Twilio SMS Credentials
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890
# Optional alternative to TWILIO_PHONE_NUMBER.
# TWILIO_MESSAGING_SERVICE_SID=MGXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Always include this phone in SOS/message SMS recipients.
# User profile mobileNumber is used as a fallback when this is empty.
REGISTERED_MOBILE_NUMBER=+919876543210
